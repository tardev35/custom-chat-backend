generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String         @id @default(uuid())
  username      String         @unique
  password      String
  name          String
  role          String         @default("STAFF")
  conversations Conversation[]
  messages      Message[]
  channels      Channel[]
}

model Channel {
  id            String         @id @default(uuid())
  name          String
  platform      String         @default("LINE")
  providerId    String         @unique
  accessToken   String?
  pictureUrl    String? // 🟢 เพิ่มฟิลด์นี้เพื่อเก็บลิงก์รูปร้าน
  conversations Conversation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cardTemplates CardTemplate[]
  admins        Admin[]
}

model CardTemplate {
  id          String  @id @default(uuid())
  title       String // ชื่อโปรโมชั่น เช่น "โปรฝาก 100", "เลขบัญชี"
  description String? // คำอธิบายให้แอดมินดู
  msgType     String // ประเภท: 'image' (รูปภาพ), 'flex' (การ์ดเดี่ยว), 'carousel' (สไลด์เลื่อน)
  imageUrl    String? // เก็บลิงก์รูป (ถ้า msgType เป็น 'image')
  flexPayload String? @db.Text // เก็บโค้ด JSON จาก LINE (ถ้า msgType เป็น flex/carousel)
  altText     String? // ข้อความแจ้งเตือนบนมือถือลูกค้า เช่น "💳 มีการ์ดถึงคุณ"

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id             String         @id @default(uuid())
  platformUserId String         @unique
  displayName    String?
  nickname       String?
  pictureUrl     String?
  tags           String         @default("") // 🟢 เพิ่มระบบแท็กเก็บป้ายกำกับ
  conversations  Conversation[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Conversation {
  id          String    @id @default(uuid())
  customerId  String    @unique
  customer    Customer  @relation(fields: [customerId], references: [id])
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id])
  assigneeId  String?
  assignee    Admin?    @relation(fields: [assigneeId], references: [id])
  botEnabled  Boolean   @default(true)
  needsAction Boolean   @default(false)
  isUnread    Boolean   @default(true)
  status      String    @default("ACTIVE")
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderType     String // เก็บค่า CUSTOMER, ADMIN, BOT, INTERNAL_NOTE
  textContent    String // ข้อความสุดท้ายที่ส่งให้ลูกค้าจริงๆ
  mediaUrl       String?
  isInternal     Boolean      @default(false)
  adminId        String?
  admin          Admin?       @relation(fields: [adminId], references: [id])
  responseTime   Int?

  // 🟢 [อัปเดตใหม่] ระบบ AI Co-Pilot Feedback Loop
  aiDraftText   String? // เก็บข้อความ "ต้นฉบับ" ที่ AI ร่างมาให้ (ถ้าแอดมินกดใช้ปุ่ม ✨)
  isDraftEdited Boolean @default(false) // True = แอดมินแก้ข้อความ, False = กดส่งเลยโดยไม่แก้

  createdAt DateTime @default(now())
}
